{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",      "color": "#0FA89A", "name": "Primary" },
        { "slug": "primary-dark", "color": "#0C7A70", "name": "Primary Dark" },
        { "slug": "primary-light","color": "#E6F6F5", "name": "Primary Light" },
        { "slug": "background",   "color": "#EFF8F6", "name": "Background" },
        { "slug": "dark-section", "color": "#1A2B2A", "name": "Dark Section" },
        { "slug": "white",        "color": "#ffffff", "name": "White" },
        { "slug": "dark",         "color": "#111827", "name": "Dark" },
        { "slug": "gray",         "color": "#6B7280", "name": "Gray" },
        { "slug": "gray-light",   "color": "#F3F4F6", "name": "Gray Light" },
        { "slug": "border",       "color": "#E5E7EB", "name": "Border" }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "inter",
          "name": "Inter",
          "fontFamily": "'Inter', sans-serif"
        },
        {
          "slug": "poppins",
          "name": "Poppins",
          "fontFamily": "'Poppins', sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "XS" },
        { "slug": "sm",   "size": "0.875rem", "name": "SM" },
        { "slug": "base", "size": "1rem",     "name": "Base" },
        { "slug": "lg",   "size": "1.125rem", "name": "LG" },
        { "slug": "xl",   "size": "1.25rem",  "name": "XL" },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2XL" },
        { "slug": "3xl",  "size": "1.875rem", "name": "3XL" },
        { "slug": "4xl",  "size": "2.25rem",  "name": "4XL" },
        { "slug": "5xl",  "size": "3rem",     "name": "5XL" },
        { "slug": "6xl",  "size": "3.75rem",  "name": "6XL" }
      ],
      "customFontSize": true,
      "lineHeight": true,
      "fluid": true
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "10", "size": "0.625rem", "name": "10" },
        { "slug": "20", "size": "1.25rem",  "name": "20" },
        { "slug": "30", "size": "1.875rem", "name": "30" },
        { "slug": "40", "size": "2.5rem",   "name": "40" },
        { "slug": "50", "size": "3rem",     "name": "50" },
        { "slug": "60", "size": "3.75rem",  "name": "60" },
        { "slug": "80", "size": "5rem",     "name": "80" },
        { "slug": "90", "size": "5.625rem", "name": "90" }
      ],
      "customSpacingSize": true,
      "units": ["px", "%", "em", "rem", "vw"]
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1180px"
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": true,
          "text": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--dark)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--poppins)",
          "fontWeight": "800",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--poppins)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--poppins)",
          "fontWeight": "600"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--poppins)",
          "fontWeight": "600"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--primary-dark)" }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "radius": "50px"
        },
        "typography": {
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--sm)"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "bottom": "12px",
            "left": "28px",
            "right": "28px"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-dark)"
          }
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "front-page",
      "title": "Startsida",
      "postTypes": ["page"]
    },
    {
      "name": "page",
      "title": "Sida",
      "postTypes": ["page"]
    },
    {
      "name": "single",
      "title": "Inlägg",
      "postTypes": ["post"]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
